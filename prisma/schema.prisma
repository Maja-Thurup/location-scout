generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Application user, mirrored from Clerk.
model User {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  email           String
  // "Crew base" used to compute driving distance to candidate locations.
  // All four are nullable until the user sets it from the dashboard.
  crewBaseAddress String?
  crewBaseLat     Float?
  crewBaseLng     Float?

  // M5 — Deep Search tier credits.
  /// Remaining "deep search" credits this month. Each user is granted
  /// 5 free deep searches per month. Decremented when the user submits
  /// a search with searchTier="deep". Reset monthly by a Vercel cron.
  /// Unlimited for users on the paid plan (handled at request-time
  /// via subscriptionTier).
  deepSearchCreditsRemaining Int @default(5)
  /// "free" (default, 5 credits/month) or "pro" (unlimited deep
  /// searches, $9/mo via Stripe — wiring deferred to a later commit).
  subscriptionTier String @default("free")
  /// Last time the monthly credit allocation was reset. Cron uses this
  /// to find users whose credits need topping up.
  lastCreditResetAt DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects       Project[]
  usageLogs      UsageLog[]
  searchHistory  SearchHistory[]

  @@index([clerkId])
}

/// A saved scouting session.
model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  sceneText String   @db.Text
  city      String
  /// Claude's structured analysis (osm_tags, google_query, bbox, visual, etc.).
  analysis  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations SavedLocation[]

  @@index([userId])
  @@index([createdAt])
}

/// One picked location inside a Project.
model SavedLocation {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Source-of-truth identifiers
  googlePlaceId String?
  osmId         String?
  // Display data
  name          String
  address       String
  lat           Float
  lng           Float
  rating        Float?
  // Photo metadata (URL only; image bytes are not cached in v1)
  photoUrl      String?
  photoSource   String? // "mapillary" | "google" | "wikimedia"
  photoAttr     String?
  // Has Street View imagery available
  hasStreetView Boolean  @default(false)
  // Free-form user notes
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

/// Generic key/value cache with TTL. Keyed by SHA-256 of the request inputs.
/// Used for Claude scene parsing, Overpass results, Google Places enrichment,
/// Mapillary photo lookups, Routes API distances.
model Cache {
  key       String   @id
  namespace String
  value     Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([namespace, expiresAt])
}

/// Auto-saved log of every successful scene parse, regardless of whether it
/// came from Claude or the cache. Surfaces as "Recent searches" on the
/// dashboard. Distinct from `Project` (M5), which is an explicit save with
/// a user-chosen title and attached locations.
model SearchHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sceneText    String   @db.Text
  /// Free-text location input from the user (city, "neighborhood, state",
  /// or street address). Column name kept as `city` for migration
  /// continuity but treated as a generic location string in the API.
  city         String?
  /// Optional search radius around the location, in miles. `null` means
  /// "use the city/area's natural bounding box" (set by Geocoding API).
  radiusMiles  Int?
  /// Claude's structured analysis at the time of this search.
  analysis     Json
  /// Whether this row was served from cache (true) or live Claude call (false).
  cached       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

/// Curated places imported from external sources (NRHP, NHL, UNESCO,
/// NPS, RIDB, NYC Scenes, SF Films, ...). Provides a free-tier-fast,
/// always-available retrieval layer that doesn't depend on third-party
/// APIs at query time.
///
/// Coordinates are stored as plain Float (lat/lng) with a btree index;
/// PostGIS isn't enabled on Supabase free tier so we filter by simple
/// bbox comparisons (`lat BETWEEN ? AND ? AND lng BETWEEN ? AND ?`)
/// which Postgres optimizes against the (lat, lng) compound index.
///
/// `tags` stores arbitrary key/value descriptors (architectural style,
/// year built, materials, named-after, ...) for tag-overlap matching.
/// `popularity` is a normalized 0-1 score used as a ranking tiebreaker.
model Place {
  /// Source-prefixed stable id, e.g. "nrhp:71001234" or "unesco:42".
  id String @id

  /// Originating source. Same enum as our provider names.
  source String

  /// Display name (e.g. "Sherman Monument").
  name String

  /// Optional one-line description (200-300 char snippets work best for
  /// downstream tag-overlap matching).
  description String? @db.Text

  /// Coordinates.
  lat Float
  lng Float

  /// Free-form tag map: { "architectural_style": "Beaux-Arts",
  /// "year_built": "1903", "material": "bronze", ... }.
  /// Stored as JSON for flexibility; queried with `@>` containment
  /// in raw SQL when needed.
  tags Json

  /// Pre-curated photo URL, when the source provides one (Wikimedia
  /// Commons, NPS, NYC Open Data, ...).
  imageUrl String?

  /// Source page URL for "Open in source" links.
  sourceUrl String?

  /// 0-1 popularity score for ranking ties. Computed at import time:
  ///   - Wikidata: log(sitelinks count) / log(50)  clamped to [0,1]
  ///   - NRHP: 1 if NHL (top 2,600), 0.5 otherwise
  ///   - UNESCO: always 1.0
  ///   - NPS, RIDB: 0.7 / 0.5 default
  popularityScore Float @default(0)

  /// When this row was last refreshed from its source.
  importedAt DateTime @default(now())

  // Compound spatial index: optimal for `lat BETWEEN ? AND ? AND
  // lng BETWEEN ? AND ?` queries. Postgres can scan within (south, north)
  // first then filter by lng. Together with the small in-memory tag-overlap
  // pass this gives sub-100ms lookups even at 200k+ rows.
  @@index([lat, lng])
  // Used by the per-source refresh-by-source code path (re-import or
  // delete by source).
  @@index([source])
}

/// Per-user, per-day usage counter for rate-limiting on the free tier.
model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String // "parse_scene" | "search_locations" | ...
  day       String // ISO date (YYYY-MM-DD), used for daily caps
  count     Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, action, day])
  @@index([userId, day])
}
