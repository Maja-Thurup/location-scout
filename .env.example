# =============================================================================
# LocationScout — environment variables template
# Copy this file to `.env.local` and fill in real values for local development.
# Set the same keys in Vercel project settings for production.
# DO NOT commit `.env.local` or `.env`.
# =============================================================================

# --- App ---
APP_URL=http://localhost:3000
NODE_ENV=development

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Google Maps Platform ---
# One key, restricted to: Places API (New), Geocoding, Maps JavaScript,
# Street View Static, Routes. Restrict to your domain in production.
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Mapillary (free street-level photos) ---
# Get from: https://www.mapillary.com/dashboard/developers
MAPILLARY_TOKEN=

# --- Supabase (Postgres + storage) ---
# Get from: Supabase Dashboard → Connect button → ORMs → Prisma
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (auth) ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Sentry (error tracking) ---
# Get DSN from: Sentry → Project Settings → Client Keys (DSN)
# Get auth token from: Sentry → User Settings → Auth Tokens (scopes:
#   Project: Read, Release: Admin, Organization: Read)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- PostHog (product analytics) ---
# Get from: PostHog → Settings → Project → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# --- TMDb (filming-location enrichment, optional) ---
# v4 read-access token (JWT). Used to fetch poster + year + popularity for
# Wikidata P915 filming locations and the "Famous films shot here" badge.
# Get from: https://www.themoviedb.org/settings/api (free, no card required)
TMDB_READ_ACCESS_TOKEN=

# --- National Park Service developer key (M7, optional) ---
# Powers the nps-places provider — National Parks + named viewpoints +
# curated photos. Free, instant signup.
# Get from: https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=

# --- Recreation.gov RIDB API key (M7, optional) ---
# Federal recreation sites (NPS + USFS + BLM): facilities, campgrounds,
# recreation areas. Free, requires recreation.gov account.
# Get from: https://ridb.recreation.gov/landing
RIDB_API_KEY=

# --- Socrata App Token (NYC Open Data, SF Open Data, ...) ---
# Required by data.cityofnewyork.us for non-trivial queries since 2024.
# Without this NYC Scenes from the City returns 403. SF Open Data also
# benefits from elevated rate limits.
# Get from: https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
# Optional: paired secret. When set we use Basic-Auth which gives a
# higher per-app rate limit and access to private datasets. Optional.
SOCRATA_APP_TOKEN_SECRET=
