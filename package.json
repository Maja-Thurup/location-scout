    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "import:unesco": "tsx scripts/import-unesco.ts",
    "import:nyc-scenes": "tsx scripts/import-nyc-scenes.ts",
    "import:sf-films": "tsx scripts/import-sf-films.ts",
    "import:nrhp": "tsx scripts/import-nrhp.ts",
    "import:all": "npm run import:unesco && npm run import:nyc-scenes && npm run import:sf-films && npm run import:nrhp"
  },
